---
// PatternBook landing page
// This is a fully custom page — NOT wrapped in Starlight layout
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PatternBook — Living Design System Documentation</title>
  <meta name="description" content="PatternBook auto-generates a living design system from your React & TypeScript components. Zero config. Instant live previews." />
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
</head>

<body>

  <!-- ── NAVBAR ─────────────────────────────────────────────────────── -->
  <nav class="navbar" id="navbar">
    <div class="nav-inner">
      <a href="/" class="nav-brand">
        <img src="/logo.svg" alt="PatternBook logo" class="nav-logo" />
        <span class="nav-title">P a t t e r n B o o k</span>
      </a>
      <div class="nav-links">        
        <a href="/getting-started" class="nav-link">Getting Started</a>
        <a href="/overview" class="nav-link">Docs</a>
        <a href="/contributing" class="nav-link">Join Us!</a>
        <a href="https://www.linkedin.com/company/PatternBook-cli" class="nav-link" target="_blank" rel="noopener">LinkedIn ↗</a>
        <a href="https://github.com/oslabs-beta/PatternBook" class="nav-link" target="_blank" rel="noopener">GitHub ↗</a>
      </div>
    </div>
  </nav>

  <!-- ── HERO ──────────────────────────────────────────────────────── -->
  <section class="hero">
    <!-- Background glow orbs -->
    <div class="glow glow-1"></div>
    <div class="glow glow-3"></div>

    <div class="hero-inner">
      <!-- Badge -->
      <div class="hero-badge glass-subtle">
        <span class="badge-dot"></span>
        O p e n - S o u r c e 
        <span class="badge-dot"></span>
      </div>

      <!-- Headline -->
      <h2 class="hero-headline">
      <span class="gradient-text">Your components </span>
      <br>   documented <span class="gradient-text">automatically</span>
      </h2>
      <!-- Subtitle -->
      <p class="hero-sub">
        PatternBook statically analyses your React &amp; TypeScript components to generate a living design system with live previews, prop tables, and source code, with no configuration required.
      </p>

  </section>

      <!-- CTAs -->
      <div class="hero-ctas">
        <a href="/getting-started" class="btn btn-primary btn-md">
          Get Started
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="https://github.com/oslabs-beta/PatternBook" class="btn btn-primary btn-md" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
          View on GitHub
        </a>
      </div>


  <!-- ── FEATURES ───────────────────────────────────────────────────── -->
  <section class="section features">
    <div class="container">
      <div class="section-label">Why PatternBook?</div>
      <h2 class="section-title">
      PatternBook is everything your design system needs.</h2>
      <p>
       PatternBook reads your code and automatically generates Documentation.</p>
      
      <div class="features-grid">


        <div class="feature-card glass">
          <h3 class="feature-title">Zero Config</h3>
          <p class="feature-desc">Point PatternBook at your components folder and it handles the rest. No YAML, no decorators, no annotations.</p>
        </div>
        <div class="feature-card glass">
          <h3 class="feature-title">Live Previews</h3>
          <p class="feature-desc">Every example is rendered live in the browser. Edit the code inline and watch the preview update in real time.</p>

          <!-- Hero visual: glass card mockup -->
      <div class="hero-card glass">
        <div class="mockup-topbar">
          <span class="dot dot-red"></span>
          <span class="dot dot-yellow"></span>
          <span class="dot dot-green"></span>
          <span class="mockup-title">Button — PatternBook</span>
        </div>
        <div class="mockup-body">
          <div class="mockup-sidebar">
            <div class="sidebar-section">Form Components</div>
            <div class="sidebar-item sidebar-item--active">Button</div>
            <div class="sidebar-item">Input</div>
            <div class="sidebar-item">Dropdown</div>
            <div class="sidebar-section">Layout</div>
            <div class="sidebar-item">Card</div>
          </div>
          <div class="mockup-content">
            <div class="mockup-header">
              <span class="mockup-name">Button</span>
              <span class="mockup-badge">function</span>
            </div>
            <div class="mockup-desc">A customizable button with multiple variants and sizes.</div>
            <div class="mockup-code">
              <span class="code-tag">&lt;</span><span class="code-comp">Button</span>
              <span class="code-prop"> variant</span><span class="code-eq">=</span><span class="code-string">"primary"</span>
              <span class="code-tag">&gt;</span>
              Click me
              <span class="code-tag">&lt;/</span><span class="code-comp">Button</span><span class="code-tag">&gt;</span>
            </div>
            <div class="mockup-preview">
              <button class="preview-btn">Click me</button>
            </div>
          </div>
        </div>
      </div>
    </div>

          
     
        <div class="feature-card glass">
          <h3 class="feature-title">Auto Prop Tables</h3>
          <p class="feature-desc">TypeScript types and JSDoc comments are extracted automatically into a searchable, filterable prop reference.</p>
        </div>
        <div class="feature-card glass">
          <h3 class="feature-title">Smart Search</h3>
          <p class="feature-desc">Find any component instantly by name, description, or tag. Categories keep everything organised as your library grows.</p>
        </div>
        <div class="feature-card glass">
          <h3 class="feature-title">Always Up-to-Date</h3>
          <p class="feature-desc">PatternBook watches your files and regenerates the manifest on every save. Your docs can never fall out of sync.</p>
        </div>
        <div class="feature-card glass">
          <h3 class="feature-title">Source Code Viewer</h3>
          <p class="feature-desc">View the full source of any component with syntax highlighting, right alongside the rendered preview.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── HOW IT WORKS ───────────────────────────────────────────────── -->
  <section class="section how">
    <div class="container">
      <div class="section-label">How it works</div>
      <h2 class="section-title">From components to docs in seconds</h2>

      <div class="steps">
        <div class="step">
          <div class="step-num">01</div>
          <div class="step-body">
            <h3 class="step-title">Install &amp; point</h3>
            <p class="step-desc">Add PatternBook to your project and point its CLI at your components directory. That's the entire setup.</p>
            <div class="step-code">
              <code>npx patternbook init</code>
            </div>
          </div>
        </div>
        <div class="step-connector"></div>
        <div class="step">
          <div class="step-num">02</div>
          <div class="step-body">
            <h3 class="step-title">Analyse &amp; generate</h3>
            <p class="step-desc">PatternBook statically analyses every component — extracting props, descriptions, examples, and source code.</p>
            <div class="step-code">
              <code>npx patternbook build</code>
            </div>
          </div>
        </div>
        <div class="step-connector"></div>
        <div class="step">
          <div class="step-num">03</div>
          <div class="step-body">
            <h3 class="step-title">View &amp; share</h3>
            <p class="step-desc">Open the PatternBook viewer to browse your living design system. Share the URL with your team.</p>
            <div class="step-code">
              <code>npx patternbook serve</code>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA ────────────────────────────────────────────────────────── -->
  <section class="section cta-section">
    <div class="container">
      <div class="cta-card glass">
        <div class="glow glow-cta"></div>
        <h2 class="cta-title">Ready to ship your design system?</h2>
        <p class="cta-sub">Get PatternBook running in your project in under five minutes.</p>
        <div class="cta-actions">
          <a href="/getting-started" class="btn btn-primary btn-md">Get Started</a>
          <a href="/overview" class="btn btn-primary btn-md">Read the Docs</a>
                  <a href="https://github.com/oslabs-beta/PatternBook" class="btn btn-primary btn-md" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
          View on GitHub
        </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FOOTER ─────────────────────────────────────────────────────── -->
  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <img src="/logo.svg" alt="PatternBook" class="footer-logo" />
        <span class="footer-name">P a t t e r n B o o k</span>
      </div>
      <p class="footer-copy">© 2026 PatternBook. Open Source under the MIT license.</p>
      <div class="footer-links">
        <a href="/overview" class="footer-link">Docs</a>
        <a href="https://github.com/oslabs-beta/PatternBook" class="footer-link" target="_blank" rel="noopener">GitHub</a>
        <a href="/getting-started" class="footer-link" target="_blank" rel="noopener">Getting Started</a>
        <a href="/overview"  class="footer-link" target="_blank" rel="noopener"> Docs</a>
        <a href="/contributing"  class="footer-link" target="_blank" rel="noopener">Join Us!</a>
        <a href="https://www.linkedin.com/company/PatternBook-cli"  class="footer-link" target="_blank" rel="noopener">LinkedIn ↗</a>
        <a href="https://github.com/oslabs-beta/PatternBook"  class="footer-link" target="_blank" rel="noopener">GitHub ↗</a>
  
  
      </div>
    </div>
  </footer>

</body>
</html>

<style>
  /* ── Reset & Base ────────────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Geist', system-ui, sans-serif;
    background: #030712;
    color: #e2e8f0;
    overflow-x: hidden;
    line-height: 1.6;
  }

  a { text-decoration: none; color: inherit; }

  /* ── Glass utilities ─────────────────────────────────────────────── */
  .glass {
    background: rgba(255, 255, 255, 0.055);
    backdrop-filter: blur(22px) saturate(180%);
    -webkit-backdrop-filter: blur(22px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 1.25rem;
    box-shadow: 0 8px 32px rgba(0, 30, 120, 0.18), inset 0 1px 0 rgba(255,255,255,0.08);
  }
  .glass-subtle {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
  }

  /* ── Layout ──────────────────────────────────────────────────────── */
  .container {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Buttons ─────────────────────────────────────────────────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: inherit;
    font-weight: 500;
    border-radius: 0.6rem;
    cursor: pointer;
    padding: .5rem;
    transition: all 0.2s ease;
    border: none;
  }
  .btn-primary {
    background: #0f2556;
    color: #fff;
    box-shadow: 0 0 0 1px #1d4ed8, 0 4px 20px rgba(37,99,235,0.35);
  }
  .btn-primary:hover {
    background: #1d4ed8;
    box-shadow: 0 0 0 1px #1e40af, 0 6px 28px rgba(37,99,235,0.5);
    transform: translateY(-1px);
  }
  .btn-ghost {
    background: rgba(255,255,255,0.07);
    color: #e2e8f0;
    border: 1px solid rgba(255,255,255,0.12);
  }
  .btn-ghost:hover { background: rgba(255,255,255,0.12); transform: translateY(-1px); }
  .btn-outline {
    background: transparent;
    color: #93c5fd;
    border: 1px solid #2563eb;
  }
  .btn-outline:hover { background: rgba(37,99,235,0.12); transform: translateY(-1px); }

  .btn-sm  { padding: 0.45rem 1rem;  font-size: 0.85rem; }
  .btn-lg  { padding: 0.75rem 1.5rem; font-size: 0.95rem; }

  /* ── Typography helpers ───────────────────────────────────────────── */
  .gradient-text {
    background: linear-gradient(135deg, #60a5fa 0%, #a78bfa 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ── NAVBAR ─────────────────────────────────────────────────────── */
  .navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 0.875rem 0;
    background: rgba(3, 7, 18, 0.6);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }
  .nav-inner {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 600;
    font-size: 1rem;
    color: #bcd6f1;
    letter-spacing: -0.01em;
  }
  .nav-logo { width: 40px; height: 40px; }
  .nav-links { display: flex; align-items: center; gap: 1.5rem; }
  .nav-link {
    font-size: 0.875rem;
    color: #94a3b8;
    transition: color 0.15s;
  }
  .nav-link:hover { color: #b3d1f0; }

  /* ── HERO ────────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 50vh;
    display: flex;
    align-items: center;
    padding: 8rem 1.5rem 5rem;
    overflow: hidden;
  }

  /* Glow orbs */
  .glow {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(80px);
    opacity: 0.45;
  }
  .glow-1 {
    width: 600px; height: 600px;
    background: radial-gradient(circle, #1d4ed8, transparent 70%);
    top: -100px; left: -100px;
  }
  .glow-2 {
    width: 500px; height: 500px;
    background: radial-gradient(circle, #6d35ce, transparent 70%);
    top: 20%; right: -200px;
    opacity: 0.25;
  }
  .glow-3 {
    width: 400px; height: 400px;
    background: radial-gradient(circle, #95b1be, transparent 70%);
    bottom: 0; left: 40%;
    opacity: 0.2;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1140px;
    margin: 0 auto;
    width: 90%;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    font-size: 0.9rem;
    color: #93c5fd;
    font-weight: 200;
  }
  .badge-dot {
    width: 6px; height: 6px;
    border-radius: 60%;
    background: #22c55e;
    box-shadow: 0 0 10px #22c55e;
  }

  .hero-headline {
    font-size: clamp(2.5rem, 6vw, 4.25rem);
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.02em;
    color: #8bbdef;
    max-width: 900px;
  }

  .hero-sub {
    font-size: 1.15rem;
    color: #8bbdef;
    max-width: 700px;
    line-height: 1.7;
    font-weight: 300;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  /* ── Hero mockup card ────────────────────────────────────────────── */
  .hero-card {
    width: 100%;
    max-width: 820px;
    margin-top: 2.5rem;
    overflow: hidden;
  }

  .mockup-topbar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1rem;
    background: rgba(0,0,0,0.3);
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }
  .dot { width: 10px; height: 10px; border-radius: 50%; }
  .dot-red    { background: #ff5f56; }
  .dot-yellow { background: #ffbd2e; }
  .dot-green  { background: #27c93f; }
  .mockup-title {
    margin-left: 0.5rem;
    font-size: 0.75rem;
    color: #64748b;
    font-family: 'Geist', monospace;
  }

  .mockup-body {
    display: flex;
    height: 260px;
  }

  .mockup-sidebar {
    width: 160px;
    min-width: 160px;
    border-right: 1px solid rgba(255,255,255,0.07);
    padding: 0.75rem 0;
  }
  .sidebar-section {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #475569;
    padding: 0.35rem 0.85rem;
  }
  .sidebar-item {
    font-size: 0.8rem;
    color: #64748b;
    padding: 0.35rem 0.85rem;
    cursor: default;
  }
  .sidebar-item--active {
    color: #60a5fa;
    background: rgba(37,99,235,0.15);
    font-weight: 500;
  }

  .mockup-content { flex: 1; padding: 1.25rem 1.5rem; }
  .mockup-header { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.5rem; }
  .mockup-name { font-size: 1.1rem; font-weight: 700; color: #f1f5f9; }
  .mockup-badge {
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    background: rgba(37,99,235,0.2);
    color: #60a5fa;
    border-radius: 0.3rem;
  }
  .mockup-desc { font-size: 0.8rem; color: #64748b; margin-bottom: 0.75rem; }

  .mockup-code {
    background: rgba(0,0,0,0.35);
    border-radius: 0.5rem;
    padding: 0.6rem 0.85rem;
    font-size: 0.8rem;
    font-family: 'Geist', monospace;
    margin-bottom: 0.85rem;
  }
  .code-tag    { color: #64748b; }
  .code-comp   { color: #60a5fa; }
  .code-prop   { color: #c084fc; }
  .code-eq     { color: #64748b; }
  .code-string { color: #86efac; }

  .mockup-preview {
    padding: 0.6rem 0.85rem;
    background: rgba(255,255,255,0.03);
    border-radius: 0.5rem;
    border: 1px solid rgba(255,255,255,0.07);
  }
  .preview-btn {
    background: #2563eb;
    color: #fff;
    border: none;
    padding: 0.4rem 1rem;
    border-radius: 0.4rem;
    font-size: 0.8rem;
    font-family: 'Geist', sans-serif;
    font-weight: 500;
    cursor: default;
  }

  /* ── SECTIONS ────────────────────────────────────────────────────── */
  .section {
    padding: 6rem 1.5rem;
    position: relative;
  }

  .section-label {
    font-size: 1.2rem;
    font-weight: 550;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #3b82f6;
    margin-bottom: 0.75rem;
    text-align: center;
  }
  .section-title {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: #7bb4ec;
    text-align: center;
    max-width: 900px;
    margin: 0 auto 1rem;
    line-height: 1.2;
  }
  .section-sub {
    font-size: 1rem;
    color: #64748b;
    text-align: center;
    max-width: 700px;
    margin: 0 auto 3.5rem;
    line-height: 1.7;
  }

  /* ── FEATURES ────────────────────────────────────────────────────── */
  .features { background: rgba(255,255,255,0.01); }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.25rem;
  }
  .feature-card {
    padding: 1.75rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .feature-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 40px rgba(0,30,120,0.25), inset 0 1px 0 rgba(255,255,255,0.1);
  }
  .feature-icon { font-size: 2rem; margin-bottom: 0.875rem; }
  .feature-title { font-size: 1.05rem; font-weight: 600; color: #f1f5f9; margin-bottom: 0.5rem; }
  .feature-desc { font-size: 0.875rem; color: #64748b; line-height: 1.7; }

