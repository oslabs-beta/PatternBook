{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node"]
  },
  "include": [
    "cli/**/*",
    "core/**/*",
    "types/**/*",
    "utils/**/*",
    "scripts/**/*",
    "test/**/*"
  ],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
