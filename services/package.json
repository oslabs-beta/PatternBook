{
  "name": "patternbook-services",
  "version": "0.1.0",
  "description": "Backend core services for PatternBook",
  "main": "cli/index.ts",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "generate-graph": "tsx scripts/test-run.ts",
    "generate-graph:full": "npm run generate-graph && mmdc -i dependency-graph.mmd -o dependency-graph.png -s 3 && mmdc -i call-graph.mmd -o call-graph.png -s 3",
    "watch:graph": "tsx scripts/test-run.ts --watch",
    "prepare": "husky",
    "pack-repo": "repomix",
    "format": "prettier --write .",
    "cli": "tsx cli/index.ts",
    "cli:dev": "tsx cli/index.ts"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^14.0.2",
    "enquirer": "^2.4.1",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5",
    "ora": "^9.1.0",
    "path": "^0.12.7",
    "prettier": "3.8.1",
    "repomix": "^1.11.1",
    "ts-morph": "^27.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mermaid-js/mermaid-cli": "^11.4.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.0.2",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
