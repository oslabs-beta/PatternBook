{
  "name": "patternbook-services",
  "version": "0.2.0",
  "type": "module",
  "bin": {
    "patternbook": "./dist/cli/index.js"
  },
  "scripts": {
    "test": "vitest",
    "build": "tsc",
    "cli": "node --loader tsx cli/index.ts",
    "cli:dev": "tsx cli/index.ts",
    "cli:build": "tsc && chmod +x dist/cli/index.js",
    "generate-graph": "tsx scripts/test-run.ts && mmdc -i dependency-graph.mmd -o dependency-graph.png",
    "watch:graph": "tsx scripts/watcher_temp.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^14.0.2",
    "enquirer": "^2.4.1",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5",
    "ora": "^9.1.0",
    "repomix": "^1.11.1",
    "ts-morph": "^27.0.2"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.4.2",
    "@types/node": "^24.10.9",
    "husky": "^9.1.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  }
}