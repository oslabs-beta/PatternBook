{
  "name": "patternbook",
  "private": true,
  "workspaces": [
    "services",
    "api",
    "client"
  ],
  "keywords": [
    "components",
    "storybook",
    "design-system",
    "cli",
    "react",
    "vue",
    "svelte"
  ],
  "homepage": "https://github.com/oslabs-beta/PatternBook#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/oslabs-beta/PatternBook.git",
    "directory": "services"
  },
  "license": "MIT",
  "bin": {
    "patternbook": "./dist/cli/index.js"
  },
  "main": "./dist/cli/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev:api": "npm run dev --workspace=api",
    "dev:client": "npm run dev --workspace=client",
    "dev:services": "npm run cli:dev --workspace=services",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:client\"",
    "build:all": "npm run build --workspaces"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}